# Public site URL (used for OG metadataBase, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://axisquant:axisquant@localhost:5432/axisquant?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Hugging Face — read-only token grants higher rate limits on Hub API
HF_TOKEN=

# GitHub — fine-grained token, read-only on org repos
GITHUB_TOKEN=

# NextAuth (Phase 6)
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend (Phase 7)
RESEND_API_KEY=
CONTACT_INBOX_EMAIL=research@axisquant.org

# Slack webhook (Phase 7) — fires on contact submissions
SLACK_WEBHOOK_URL=

# Cloudflare Turnstile (Phase 7)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
